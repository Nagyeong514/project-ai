# ================================================================
# 암묵지 추출 파이프라인 환경 변수 템플릿
# ================================================================
# 사용법: 이 파일을 복사하여 .env 로 저장한 후 실제 값을 채우세요.
#   cp .env.example .env
#
# 주의: .env 파일은 절대 git에 커밋하지 마세요. (.gitignore 처리됨)
# ================================================================


# ----------------------------------------------------------------
# MySQL 접속 정보
# loader.py / pipeline.py DB 연결에 사용됩니다.
# ----------------------------------------------------------------

# MySQL 서버 주소 (로컬이면 localhost, 원격이면 IP 또는 도메인)
DB_HOST=localhost

# MySQL 포트 (기본값 3306, 변경한 경우 수정)
DB_PORT=3306

# DB 사용자 이름
DB_USER=root

# DB 비밀번호
DB_PASSWORD=your_mysql_password_here

# 대상 데이터베이스 이름 (db/init.sql 실행 후 생성됨)
DB_NAME=tacit_knowledge_db


# ----------------------------------------------------------------
# Google Gemini API 키
# synthesizer.py의 Stage 3 암묵지 분석에 사용됩니다.
# 발급: https://aistudio.google.com/app/apikey
# ----------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
