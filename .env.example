# 이 파일을 복사하여 .env 로 저장한 후 실제 값을 채우세요.
# cp .env.example .env

# MySQL 접속 정보 (loader.py 사용)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=tacit_knowledge_db

# Google Gemini API 키 (synthesizer.py 사용)
# 발급 경로: https://aistudio.google.com/app/apikey
GEMINI_API_KEY= 본인 키를 입력하세요
